{
  "name": "openai-agents",
  "version": "0.0.1",
  "description": "OpenAI Agents SDK for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "openai",
    "agents",
    "llm",
    "ai"
  ],
  "author": "OpenAI",
  "license": "MIT",
  "dependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "openai": "^4.93.0",
    "ts-jest": "^29.3.1",
    "typescript": "^5.8.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3"
  }
}
